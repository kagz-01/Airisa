# AI Configuration
# You can use any OpenAI-compatible provider (OpenAI, Groq, DeepSeek, Ollama, etc.)

# Example for Groq (Fast & Free tier available)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=gsk_...
# AI_MODEL=llama3-8b-8192

# Example for OpenAI
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-3.5-turbo

# Example for Local Ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3

AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama3-8b-8192
